---
export const prerender = false;
import AppLayout from "../../../layouts/AppLayout.astro";
import { getDb, schema } from "../../../lib/db";
import { eq } from "drizzle-orm";

const db = getDb();
const tenantId = Astro.locals.tenantId;
const users = await db.select({ id: schema.users.id, name: schema.users.name, email: schema.users.email, role: schema.users.role, active: schema.users.active })
  .from(schema.users).where(eq(schema.users.tenantId, tenantId)).orderBy(schema.users.name);
const warehouses = await db.select({ id: schema.warehouses.id, name: schema.warehouses.name })
  .from(schema.warehouses).where(eq(schema.warehouses.tenantId, tenantId));

const roleLabel: Record<string, { label: string; cls: string }> = {
  owner:   { label: "Dueño",     cls: "bg-blue-50 text-brand-blue" },
  admin:   { label: "Admin",     cls: "bg-orange-50 text-orange-700" },
  manager: { label: "Gerente",   cls: "bg-success-50 text-success-500" },
  cashier: { label: "Cajero",    cls: "bg-neutral-100 text-neutral-600" },
};
---

<AppLayout title="Usuarios" activeRoute="">
  <div class="mx-auto max-w-5xl px-4 py-6 md:px-6 md:py-8">
    <header class="mb-6 flex flex-wrap items-end justify-between gap-4">
      <div>
        <a href="/app/configuracion" class="inline-flex items-center gap-2 text-sm font-semibold text-brand-blue hover:underline">
          <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
          Volver a configuración
        </a>
        <h1 class="mt-3 font-heading text-2xl font-bold text-neutral-900 md:text-3xl">Usuarios y permisos</h1>
        <p class="mt-1 text-sm text-neutral-500">{users.length} usuario{users.length === 1 ? "" : "s"} en tu farmacia</p>
      </div>
      <button id="btn-invite" class="rounded-lg bg-brand-blue px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-800">+ Invitar usuario</button>
    </header>

    <div class="overflow-hidden rounded-2xl border border-neutral-200 bg-white shadow-card">
      <table class="w-full text-sm">
        <thead class="bg-neutral-50">
          <tr class="text-left text-xs font-semibold uppercase tracking-wider text-neutral-500">
            <th class="px-4 py-3 md:px-5">Nombre</th>
            <th class="px-4 py-3 md:px-5">Email</th>
            <th class="px-4 py-3 text-center md:px-5">Rol</th>
            <th class="px-4 py-3 text-center md:px-5">Estado</th>
          </tr>
        </thead>
        <tbody class="divide-y divide-neutral-100">
          {users.map((u) => {
            const r = roleLabel[u.role] ?? { label: u.role, cls: "bg-neutral-100 text-neutral-600" };
            return (
              <tr>
                <td class="px-4 py-3 font-medium text-neutral-900 md:px-5">{u.name}</td>
                <td class="px-4 py-3 text-neutral-600 md:px-5">{u.email}</td>
                <td class="px-4 py-3 text-center md:px-5"><span class={`inline-block rounded-full px-2 py-0.5 text-[10px] font-semibold ${r.cls}`}>{r.label}</span></td>
                <td class="px-4 py-3 text-center md:px-5"><span class={`inline-block rounded-full px-2 py-0.5 text-[10px] font-semibold ${u.active ? "bg-success-50 text-success-500" : "bg-danger-50 text-danger-500"}`}>{u.active ? "Activo" : "Inactivo"}</span></td>
              </tr>
            );
          })}
        </tbody>
      </table>
    </div>

    <div id="modal" class="fixed inset-0 z-30 hidden items-center justify-center bg-neutral-900/40 p-4">
      <div class="w-full max-w-md rounded-2xl bg-white p-6 shadow-popover">
        <h2 class="font-heading text-xl font-bold text-neutral-900">Invitar usuario</h2>
        <p class="mt-1 text-sm text-neutral-500">Define la contraseña inicial. El usuario podrá cambiarla luego en su perfil.</p>
        <form id="form-invite" class="mt-4 space-y-3">
          <label class="block">
            <span class="mb-1 block text-xs font-semibold uppercase tracking-wider text-neutral-500">Nombre *</span>
            <input name="name" required class="w-full rounded-lg border border-neutral-200 bg-neutral-50 px-3 py-2.5 text-sm focus:border-blue-300 focus:bg-white focus:outline-none" />
          </label>
          <label class="block">
            <span class="mb-1 block text-xs font-semibold uppercase tracking-wider text-neutral-500">Email *</span>
            <input name="email" type="email" required class="w-full rounded-lg border border-neutral-200 bg-neutral-50 px-3 py-2.5 text-sm focus:border-blue-300 focus:bg-white focus:outline-none" />
          </label>
          <label class="block">
            <span class="mb-1 block text-xs font-semibold uppercase tracking-wider text-neutral-500">Contraseña inicial *</span>
            <input name="password" type="password" required minlength="8" class="w-full rounded-lg border border-neutral-200 bg-neutral-50 px-3 py-2.5 text-sm focus:border-blue-300 focus:bg-white focus:outline-none" />
          </label>
          <div class="grid gap-3 sm:grid-cols-2">
            <label class="block">
              <span class="mb-1 block text-xs font-semibold uppercase tracking-wider text-neutral-500">Rol</span>
              <select name="role" class="w-full rounded-lg border border-neutral-200 bg-neutral-50 px-3 py-2.5 text-sm focus:border-blue-300 focus:bg-white focus:outline-none">
                <option value="cashier">Cajero</option>
                <option value="manager">Gerente</option>
                <option value="admin">Admin</option>
              </select>
            </label>
            <label class="block">
              <span class="mb-1 block text-xs font-semibold uppercase tracking-wider text-neutral-500">Sucursal asignada</span>
              <select name="defaultWarehouseId" class="w-full rounded-lg border border-neutral-200 bg-neutral-50 px-3 py-2.5 text-sm focus:border-blue-300 focus:bg-white focus:outline-none">
                {warehouses.map((w) => (<option value={w.id}>{w.name}</option>))}
              </select>
            </label>
          </div>
          <div id="invite-error" class="hidden rounded-lg bg-danger-50 px-3 py-2 text-sm text-danger-500"></div>
          <div class="flex gap-2 pt-2">
            <button type="button" id="cancel-invite" class="flex-1 rounded-lg border border-neutral-200 bg-white px-4 py-2.5 text-sm font-medium text-neutral-700">Cancelar</button>
            <button type="submit" class="flex-1 rounded-lg bg-brand-blue px-4 py-2.5 text-sm font-semibold text-white">Crear usuario</button>
          </div>
        </form>
      </div>
    </div>
  </div>
</AppLayout>

<script is:inline>
  document.getElementById("btn-invite")?.addEventListener("click", () => { document.getElementById("modal").classList.replace("hidden", "flex"); });
  document.getElementById("cancel-invite")?.addEventListener("click", () => { document.getElementById("modal").classList.replace("flex", "hidden"); });
  document.getElementById("form-invite")?.addEventListener("submit", async (e) => {
    e.preventDefault();
    const fd = new FormData(e.target);
    const data = Object.fromEntries(fd);
    if (data.defaultWarehouseId) data.defaultWarehouseId = Number(data.defaultWarehouseId);
    const err = document.getElementById("invite-error");
    err.classList.add("hidden");
    const res = await fetch("/api/users/invite", { method: "POST", headers: { "Content-Type": "application/json" }, body: JSON.stringify(data) });
    const json = await res.json();
    if (json.ok) { window.location.reload(); }
    else { err.textContent = json.error; err.classList.remove("hidden"); }
  });
</script>
