---
export const prerender = false;
import AppLayout from "../../layouts/AppLayout.astro";
---

<AppLayout title="Proveedores" activeRoute="proveedores">
  <div class="mx-auto max-w-3xl px-4 py-16 md:px-6">
    <div class="rounded-3xl border border-neutral-200 bg-white p-10 text-center shadow-card">
      <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-2xl bg-blue-50">
        <svg class="h-8 w-8 text-brand-blue" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6">
          <path d="M3 21V11l6 3V8l6 4V4l6 3v14H3zM7 17h2M11 17h2M15 17h2" />
        </svg>
      </div>
      <h1 class="font-heading text-2xl font-bold text-neutral-900">Proveedores</h1>
      <p class="mx-auto mt-3 max-w-md text-sm leading-relaxed text-neutral-500">
        Aquí vas a poder dar de alta a Casa Saba, Nadro, Marzam, Pfizer y a cualquier proveedor con quien trabajes,
        guardar sus contactos y disparar órdenes de compra desde inventario.
      </p>
      <span class="mt-6 inline-block rounded-full bg-orange-50 px-3 py-1 text-xs font-bold text-orange-700">
        Disponible en Fase 2
      </span>
    </div>
  </div>
</AppLayout>
