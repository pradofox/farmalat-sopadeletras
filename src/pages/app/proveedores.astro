---
export const prerender = false;
import AppLayout from "../../layouts/AppLayout.astro";
import { getDb, schema } from "../../lib/db";
import { eq, like, or, and } from "drizzle-orm";

const db = getDb();
const tenantId = Astro.locals.tenantId;
const q = (Astro.url.searchParams.get("q") ?? "").trim();

const where = q
  ? and(eq(schema.suppliers.tenantId, tenantId), or(like(schema.suppliers.name, `%${q}%`), like(schema.suppliers.email, `%${q}%`)))
  : eq(schema.suppliers.tenantId, tenantId);

const suppliers = await db.select().from(schema.suppliers).where(where).orderBy(schema.suppliers.name).limit(500);
---

<AppLayout title="Proveedores" activeRoute="proveedores">
  <div class="mx-auto max-w-7xl px-4 py-6 md:px-6 md:py-8">
    <header class="mb-6 flex flex-wrap items-end justify-between gap-4">
      <div>
        <h1 class="font-heading text-2xl font-bold text-neutral-900 md:text-3xl">Proveedores</h1>
        <p class="mt-1 text-sm text-neutral-500">{suppliers.length} {suppliers.length === 1 ? "proveedor" : "proveedores"}</p>
      </div>
      <a href="/app/proveedores/nuevo" class="rounded-lg bg-brand-blue px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-800">+ Nuevo proveedor</a>
    </header>

    <form method="get" class="mb-4">
      <div class="relative max-w-xl">
        <svg class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-neutral-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="11" cy="11" r="7"/><path d="M21 21l-4-4"/></svg>
        <input name="q" type="search" value={q} placeholder="Buscar por nombre o email" class="w-full rounded-lg border border-neutral-200 bg-white py-2.5 pl-10 pr-3 text-sm focus:border-blue-300 focus:outline-none" />
      </div>
    </form>

    <div class="overflow-hidden rounded-2xl border border-neutral-200 bg-white shadow-card">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-neutral-50">
            <tr class="text-left text-xs font-semibold uppercase tracking-wider text-neutral-500">
              <th class="px-4 py-3 md:px-5">Proveedor</th>
              <th class="hidden px-4 py-3 md:table-cell md:px-5">Contacto</th>
              <th class="hidden px-4 py-3 lg:table-cell lg:px-5">Email</th>
              <th class="hidden px-4 py-3 lg:table-cell lg:px-5">Teléfono</th>
              <th class="hidden px-4 py-3 lg:table-cell lg:px-5">Términos</th>
              <th class="w-20"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-neutral-100">
            {suppliers.map((s) => (
              <tr class="transition hover:bg-blue-50/40">
                <td class="px-4 py-3 font-medium text-neutral-900 md:px-5">{s.name}</td>
                <td class="hidden px-4 py-3 text-neutral-600 md:table-cell md:px-5">{s.contactName ?? "—"}</td>
                <td class="hidden px-4 py-3 text-neutral-600 lg:table-cell lg:px-5">{s.email ?? "—"}</td>
                <td class="hidden px-4 py-3 text-neutral-600 lg:table-cell lg:px-5">{s.phone ?? "—"}</td>
                <td class="hidden px-4 py-3 text-neutral-600 lg:table-cell lg:px-5">{s.paymentTerms ?? "—"}</td>
                <td class="px-2 py-3">
                  <a href={`/app/proveedores/${s.id}`} class="rounded p-1 text-neutral-400 transition hover:bg-blue-50 hover:text-brand-blue" aria-label="Editar">
                    <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M11 4h-7v16h16v-7M18 2l4 4-10 10h-4v-4z"/></svg>
                  </a>
                </td>
              </tr>
            ))}
            {suppliers.length === 0 && (<tr><td colspan="6" class="px-5 py-16 text-center text-sm text-neutral-400">Sin proveedores. Crea uno o re-seedea.</td></tr>)}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</AppLayout>
