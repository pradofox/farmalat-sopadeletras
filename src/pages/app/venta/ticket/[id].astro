---
export const prerender = false;
import "../../../../styles/global.css";
import { getDb, schema } from "../../../../lib/db";
import { and, eq } from "drizzle-orm";

const db = getDb();
const tenantId = Astro.locals.tenantId;

const saleId = Number(Astro.params.id);
if (!saleId) return Astro.redirect("/app");

const [sale] = await db
  .select()
  .from(schema.sales)
  .where(and(eq(schema.sales.id, saleId), eq(schema.sales.tenantId, tenantId)))
  .limit(1);
if (!sale) return Astro.redirect("/app");

const items = await db
  .select()
  .from(schema.saleItems)
  .where(eq(schema.saleItems.saleId, sale.id));

const pays = await db
  .select()
  .from(schema.payments)
  .where(eq(schema.payments.saleId, sale.id));

const [warehouse] = await db
  .select()
  .from(schema.warehouses)
  .where(eq(schema.warehouses.id, sale.warehouseId))
  .limit(1);

const fmt = (n: number) => "$" + n.toLocaleString("es-MX", { minimumFractionDigits: 2, maximumFractionDigits: 2 });
const methodLabel: Record<string, string> = {
  cash: "Efectivo",
  card_debit: "Tarjeta débito",
  card_credit: "Tarjeta crédito",
  transfer: "Transferencia",
  wallet: "Monedero",
  credit: "Crédito",
};

const fechaHora = sale.createdAt
  ? new Date(sale.createdAt).toLocaleString("es-MX", { dateStyle: "medium", timeStyle: "short" })
  : "";
---

<!doctype html>
<html lang="es-MX">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@500;600&display=swap" rel="stylesheet" />
    <title>Ticket {sale.ticketNumber} · FarmaLat</title>
    <style>
      @media print {
        @page { size: 80mm auto; margin: 0; }
        body { background: white; }
        .no-print { display: none !important; }
        .ticket { box-shadow: none !important; border: 0 !important; margin: 0; max-width: none; width: 80mm; }
      }
    </style>
  </head>
  <body class="min-h-screen bg-neutral-100 antialiased">
    <!-- Toolbar pantalla -->
    <div class="no-print mx-auto flex max-w-3xl items-center justify-between px-4 py-4">
      <a href="/app/venta" class="flex items-center gap-2 text-sm font-semibold text-brand-blue hover:underline">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round">
          <path d="M19 12H5M12 19l-7-7 7-7" />
        </svg>
        Nueva venta
      </a>
      <div class="flex gap-2">
        <button
          type="button"
          onclick="window.print()"
          class="rounded-lg bg-brand-blue px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-blue-800"
        >
          Imprimir ticket
        </button>
        <a
          href="/app"
          class="rounded-lg border border-neutral-200 bg-white px-4 py-2 text-sm font-medium text-neutral-700"
        >
          Inicio
        </a>
      </div>
    </div>

    <!-- Ticket -->
    <div class="ticket mx-auto max-w-[320px] border border-neutral-200 bg-white px-5 py-6 text-[12px] leading-tight shadow-card md:max-w-[360px]">
      <header class="text-center">
        <img src="/brand/farmalat-isotipo-blue.svg" alt="" class="mx-auto h-10 w-10" />
        <h1 class="mt-2 font-heading text-base font-bold text-neutral-900">{warehouse?.ticketLine1 ?? "Farmacia"}</h1>
        {warehouse?.ticketLine2 && <p class="mt-0.5 text-neutral-600">{warehouse.ticketLine2}</p>}
        {warehouse?.ticketLine3 && <p class="text-neutral-600">{warehouse.ticketLine3}</p>}
      </header>

      <div class="my-3 border-t border-dashed border-neutral-300" />

      <div class="space-y-0.5 font-mono text-[11px]">
        <div class="flex justify-between"><span class="text-neutral-500">Ticket</span><span class="font-bold text-neutral-900">{sale.ticketNumber}</span></div>
        <div class="flex justify-between"><span class="text-neutral-500">Fecha</span><span class="text-neutral-700">{fechaHora}</span></div>
        <div class="flex justify-between"><span class="text-neutral-500">Cajero</span><span class="text-neutral-700">Lilian B.</span></div>
      </div>

      <div class="my-3 border-t border-dashed border-neutral-300" />

      <table class="w-full text-[11px]">
        <thead>
          <tr class="border-b border-neutral-300 text-left text-[10px] uppercase tracking-wider text-neutral-500">
            <th class="pb-1 text-center">Cnt</th>
            <th class="pb-1">Producto</th>
            <th class="pb-1 text-right">Total</th>
          </tr>
        </thead>
        <tbody>
          {items.map((it) => (
            <tr class="align-top">
              <td class="py-1 pr-2 text-center font-mono text-neutral-700">{it.quantity}</td>
              <td class="py-1">
                <div class="text-neutral-900">{it.productName}</div>
                <div class="font-mono text-[10px] text-neutral-500">{fmt(it.unitPrice)} c/u{it.ivaPct > 0 ? ` · IVA ${it.ivaPct}%` : ""}</div>
              </td>
              <td class="py-1 text-right font-mono font-semibold tabular text-neutral-900">{fmt(it.total)}</td>
            </tr>
          ))}
        </tbody>
      </table>

      <div class="my-3 border-t border-dashed border-neutral-300" />

      <div class="space-y-1 font-mono text-[11px]">
        <div class="flex justify-between"><span class="text-neutral-500">Subtotal</span><span class="tabular text-neutral-700">{fmt(sale.subtotal)}</span></div>
        <div class="flex justify-between"><span class="text-neutral-500">IVA</span><span class="tabular text-neutral-700">{fmt(sale.ivaTotal)}</span></div>
        <div class="mt-2 flex items-center justify-between border-t border-neutral-300 pt-2 font-heading text-sm font-bold">
          <span>Total</span><span class="font-mono tabular text-brand-blue">{fmt(sale.total)}</span>
        </div>
      </div>

      <div class="my-3 border-t border-dashed border-neutral-300" />

      <div class="space-y-0.5 font-mono text-[11px]">
        <div class="text-neutral-500">Forma de pago:</div>
        {pays.map((p) => (
          <div class="flex justify-between">
            <span class="text-neutral-700">{methodLabel[p.method] ?? p.method}</span>
            <span class="tabular text-neutral-900">{fmt(p.amount)}</span>
          </div>
        ))}
      </div>

      <div class="my-3 border-t border-dashed border-neutral-300" />

      <div class="text-center text-[10px] leading-relaxed text-neutral-500">
        <p>¿Necesitas factura?</p>
        <p>Solicítala en farmalat.sopadeletras.art con</p>
        <p>folio <strong>{sale.ticketNumber}</strong> dentro de los próximos 30 días.</p>
        <p class="mt-3 font-heading text-[10px] font-bold text-brand-blue">¡Gracias por tu compra!</p>
        <p class="mt-1 text-[9px] text-neutral-400">Hecho con FarmaLat</p>
      </div>
    </div>

    <script>
      // Imprimir directo si llega con ?print=1
      if (new URLSearchParams(window.location.search).get("print") === "1") {
        setTimeout(() => window.print(), 300);
      }
    </script>
  </body>
</html>
