---
export const prerender = false;
import AppLayout from "../../layouts/AppLayout.astro";
---

<AppLayout title="Órdenes" activeRoute="ordenes">
  <div class="mx-auto max-w-3xl px-4 py-16 md:px-6">
    <div class="rounded-3xl border border-neutral-200 bg-white p-10 text-center shadow-card">
      <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-2xl bg-blue-50">
        <svg class="h-8 w-8 text-brand-blue" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round">
          <path d="M3 7h12v8H3zM15 11h4l2 3v1h-6zM6 18a1.5 1.5 0 100-3 1.5 1.5 0 000 3zm12 0a1.5 1.5 0 100-3 1.5 1.5 0 000 3z" />
        </svg>
      </div>
      <h1 class="font-heading text-2xl font-bold text-neutral-900">Órdenes a proveedor y traslados</h1>
      <p class="mx-auto mt-3 max-w-md text-sm leading-relaxed text-neutral-500">
        Generar requisiciones, enviar órdenes por correo al proveedor, recibirlas y mover producto entre sucursales en un mismo flujo.
      </p>
      <span class="mt-6 inline-block rounded-full bg-orange-50 px-3 py-1 text-xs font-bold text-orange-700">
        Disponible en Fase 2
      </span>
    </div>
  </div>
</AppLayout>
