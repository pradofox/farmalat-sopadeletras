---
export const prerender = false;
import AppLayout from "../../layouts/AppLayout.astro";
import { getDb, schema } from "../../lib/db";
import { eq, desc } from "drizzle-orm";

const db = getDb();
const tenantId = Astro.locals.tenantId;

const orders = await db
  .select({
    id: schema.supplierOrders.id,
    orderNumber: schema.supplierOrders.orderNumber,
    status: schema.supplierOrders.status,
    total: schema.supplierOrders.total,
    expectedAt: schema.supplierOrders.expectedAt,
    createdAt: schema.supplierOrders.createdAt,
    supplier: schema.suppliers.name,
    warehouse: schema.warehouses.name,
  })
  .from(schema.supplierOrders)
  .leftJoin(schema.suppliers, eq(schema.supplierOrders.supplierId, schema.suppliers.id))
  .leftJoin(schema.warehouses, eq(schema.supplierOrders.warehouseId, schema.warehouses.id))
  .where(eq(schema.supplierOrders.tenantId, tenantId))
  .orderBy(desc(schema.supplierOrders.createdAt))
  .limit(200);

const fmt = (n: number) => "$" + Number(n).toLocaleString("es-MX", { minimumFractionDigits: 2 });
const fmtDate = (d: Date | null) => d ? new Date(d).toLocaleDateString("es-MX", { dateStyle: "short" }) : "—";

const statusLabel: Record<string, { label: string; cls: string }> = {
  draft:    { label: "Borrador",         cls: "bg-neutral-100 text-neutral-600" },
  sent:     { label: "Enviada",          cls: "bg-blue-50 text-brand-blue" },
  partial:  { label: "Recibida parcial", cls: "bg-warning-50 text-warning-500" },
  received: { label: "Recibida",         cls: "bg-success-50 text-success-500" },
  cancelled:{ label: "Cancelada",        cls: "bg-danger-50 text-danger-500" },
};
---

<AppLayout title="Órdenes a proveedor" activeRoute="ordenes">
  <div class="mx-auto max-w-7xl px-4 py-6 md:px-6 md:py-8">
    <header class="mb-6 flex flex-wrap items-end justify-between gap-4">
      <div>
        <h1 class="font-heading text-2xl font-bold text-neutral-900 md:text-3xl">Órdenes a proveedor</h1>
        <p class="mt-1 text-sm text-neutral-500">{orders.length} órdenes recientes</p>
      </div>
      <a href="/app/ordenes/nueva" class="rounded-lg bg-brand-blue px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-800">+ Nueva orden</a>
    </header>

    <div class="overflow-hidden rounded-2xl border border-neutral-200 bg-white shadow-card">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-neutral-50">
            <tr class="text-left text-xs font-semibold uppercase tracking-wider text-neutral-500">
              <th class="px-4 py-3 md:px-5">Orden</th>
              <th class="px-4 py-3 md:px-5">Fecha</th>
              <th class="px-4 py-3 md:px-5">Proveedor</th>
              <th class="hidden px-4 py-3 md:table-cell md:px-5">Almacén</th>
              <th class="hidden px-4 py-3 md:table-cell md:px-5">Esperada</th>
              <th class="px-4 py-3 text-center md:px-5">Estado</th>
              <th class="px-4 py-3 text-right md:px-5">Total</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-neutral-100">
            {orders.map((o) => {
              const st = statusLabel[o.status] ?? statusLabel.draft;
              return (
                <tr class="cursor-pointer transition hover:bg-blue-50/40" onclick={`window.location='/app/ordenes/${o.id}'`}>
                  <td class="px-4 py-3 font-mono text-xs font-semibold text-brand-blue md:px-5">{o.orderNumber}</td>
                  <td class="px-4 py-3 text-neutral-600 md:px-5">{fmtDate(o.createdAt)}</td>
                  <td class="px-4 py-3 text-neutral-900 md:px-5">{o.supplier ?? "—"}</td>
                  <td class="hidden px-4 py-3 text-neutral-600 md:table-cell md:px-5">{o.warehouse ?? "—"}</td>
                  <td class="hidden px-4 py-3 text-neutral-600 md:table-cell md:px-5">{fmtDate(o.expectedAt)}</td>
                  <td class="px-4 py-3 text-center md:px-5"><span class={`inline-block rounded-full px-2 py-0.5 text-[10px] font-semibold ${st.cls}`}>{st.label}</span></td>
                  <td class="px-4 py-3 text-right font-mono font-semibold tabular text-neutral-900 md:px-5">{fmt(o.total)}</td>
                </tr>
              );
            })}
            {orders.length === 0 && (
              <tr><td colspan="7" class="px-5 py-16 text-center text-sm text-neutral-400">
                Sin órdenes aún. <a href="/app/ordenes/nueva" class="font-semibold text-brand-blue hover:underline">Crear la primera</a>.
              </td></tr>
            )}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</AppLayout>
