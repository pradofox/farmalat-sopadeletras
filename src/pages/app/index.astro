---
import AppLayout from "../../layouts/AppLayout.astro";

const kpis = [
  { label: "Ventas hoy",       value: "$12,847.50", delta: "+8.4%",  positive: true },
  { label: "Tickets hoy",      value: "47",          delta: "+12",    positive: true },
  { label: "Productos bajo mínimo", value: "8",      delta: "Revisar", positive: false },
  { label: "Comisiones del mes", value: "$3,210",    delta: "Mar.",    positive: true },
];

const recentSales = [
  { ticket: "26051200047", time: "13:42", cashier: "Virgilio", total: "$382.50", items: 3 },
  { ticket: "26051200046", time: "13:31", cashier: "Virgilio", total: "$1,047.00", items: 7 },
  { ticket: "26051200045", time: "13:18", cashier: "Sandy",    total: "$92.00",   items: 1 },
  { ticket: "26051200044", time: "13:04", cashier: "Virgilio", total: "$56.40",   items: 2 },
  { ticket: "26051200043", time: "12:51", cashier: "Sandy",    total: "$215.30",  items: 4 },
];

const lowStock = [
  { name: "AMOXICILINA 875MG C/10 TABS",    barcode: "7501349026230", stock: 2, min: 10 },
  { name: "PARACETAMOL 750MG C/10 TABS",     barcode: "7502209851078", stock: 4, min: 12 },
  { name: "OMEPRAZOL 20MG C/14 CAP",         barcode: "7501006030051", stock: 1, min: 8  },
  { name: "LORATADINA 10MG C/20 TABS",       barcode: "7502211783787", stock: 3, min: 6  },
];
---

<AppLayout title="Inicio" activeRoute="">
  <div class="mx-auto max-w-7xl px-6 py-8">
    <header class="mb-8">
      <h1 class="font-heading text-3xl font-bold text-neutral-900">
        Buenos días, Virgilio
      </h1>
      <p class="mt-1 text-sm text-neutral-500">
        Martes, 12 de mayo · Farmacia Alfa Matriz
      </p>
    </header>

    <!-- KPIs -->
    <section class="mb-8 grid gap-4 md:grid-cols-2 lg:grid-cols-4">
      {kpis.map((kpi) => (
        <article class="rounded-2xl border border-neutral-200 bg-white p-5 shadow-card">
          <div class="text-xs font-medium uppercase tracking-wider text-neutral-500">
            {kpi.label}
          </div>
          <div class="mt-2 font-mono text-3xl font-bold tabular text-neutral-900">
            {kpi.value}
          </div>
          <div class={
            "mt-1 inline-flex items-center gap-1 rounded-full px-2 py-0.5 text-xs font-semibold " +
            (kpi.positive ? "bg-success-50 text-success-500" : "bg-warning-50 text-warning-500")
          }>
            {kpi.delta}
          </div>
        </article>
      ))}
    </section>

    <!-- Recent + Low stock -->
    <div class="grid gap-6 lg:grid-cols-3">
      <!-- Ventas recientes -->
      <section class="rounded-2xl border border-neutral-200 bg-white shadow-card lg:col-span-2">
        <header class="flex items-center justify-between border-b border-neutral-200 px-5 py-4">
          <h2 class="font-heading text-lg font-bold text-neutral-900">Ventas recientes</h2>
          <a href="/app/historial" class="text-sm font-semibold text-brand-blue hover:underline">
            Ver historial completo
          </a>
        </header>
        <table class="w-full text-sm">
          <thead>
            <tr class="border-b border-neutral-200 text-left text-xs font-semibold uppercase tracking-wider text-neutral-500">
              <th class="px-5 py-3">Ticket</th>
              <th class="px-5 py-3">Hora</th>
              <th class="px-5 py-3">Cajero</th>
              <th class="px-5 py-3 text-right">Productos</th>
              <th class="px-5 py-3 text-right">Total</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-neutral-100">
            {recentSales.map((s) => (
              <tr class="transition hover:bg-blue-50/50">
                <td class="px-5 py-3 font-mono text-xs text-neutral-700">{s.ticket}</td>
                <td class="px-5 py-3 text-neutral-600">{s.time}</td>
                <td class="px-5 py-3 text-neutral-700">{s.cashier}</td>
                <td class="px-5 py-3 text-right text-neutral-600">{s.items}</td>
                <td class="px-5 py-3 text-right font-mono font-semibold tabular text-neutral-900">{s.total}</td>
              </tr>
            ))}
          </tbody>
        </table>
      </section>

      <!-- Stock bajo -->
      <section class="rounded-2xl border border-neutral-200 bg-white shadow-card">
        <header class="flex items-center justify-between border-b border-neutral-200 px-5 py-4">
          <h2 class="font-heading text-lg font-bold text-neutral-900">Stock crítico</h2>
          <span class="rounded-full bg-danger-50 px-2 py-0.5 text-xs font-bold text-danger-500">
            {lowStock.length}
          </span>
        </header>
        <ul class="divide-y divide-neutral-100">
          {lowStock.map((p) => (
            <li class="px-5 py-3">
              <div class="text-sm font-medium text-neutral-900">{p.name}</div>
              <div class="mt-1 flex items-center justify-between">
                <span class="font-mono text-xs text-neutral-500">{p.barcode}</span>
                <span class="font-mono text-xs font-semibold tabular text-danger-500">
                  {p.stock} / {p.min}
                </span>
              </div>
            </li>
          ))}
        </ul>
        <div class="border-t border-neutral-200 px-5 py-3">
          <a href="/app/reportes/min-max" class="text-sm font-semibold text-brand-blue hover:underline">
            Generar requisición →
          </a>
        </div>
      </section>
    </div>
  </div>
</AppLayout>
