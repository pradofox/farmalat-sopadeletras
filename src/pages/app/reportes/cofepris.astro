---
export const prerender = false;
import AppLayout from "../../../layouts/AppLayout.astro";
import Kpi from "../../../components/Kpi.astro";
import { getDb, schema } from "../../../lib/db";
import { and, eq, gte, lte, desc, sql } from "drizzle-orm";

const db = getDb();
const tenantId = Astro.locals.tenantId;

const today = new Date(); today.setHours(23, 59, 59, 999);
const monthStart = new Date(today.getFullYear(), today.getMonth(), 1);
const fromStr = Astro.url.searchParams.get("from") ?? monthStart.toISOString().slice(0, 10);
const toStr = Astro.url.searchParams.get("to") ?? today.toISOString().slice(0, 10);
const group = (Astro.url.searchParams.get("group") ?? "all") as "all" | "I" | "II" | "III" | "IV";

const fromTs = new Date(fromStr + "T00:00:00").getTime();
const toTs = new Date(toStr + "T23:59:59.999").getTime();

const baseConds = [
  eq(schema.inventoryMovements.tenantId, tenantId),
  gte(schema.inventoryMovements.createdAt, new Date(fromTs)),
  lte(schema.inventoryMovements.createdAt, new Date(toTs)),
];

const groupedConds = group !== "all"
  ? [...baseConds, eq(schema.inventoryMovements.controlledGroup, group as any)]
  : [...baseConds, sql`${schema.inventoryMovements.controlledGroup} IS NOT NULL`];

const movs = await db
  .select({
    id: schema.inventoryMovements.id,
    createdAt: schema.inventoryMovements.createdAt,
    type: schema.inventoryMovements.type,
    quantity: schema.inventoryMovements.quantity,
    balanceAfter: schema.inventoryMovements.balanceAfter,
    controlledGroup: schema.inventoryMovements.controlledGroup,
    product: schema.products.name,
    barcode: schema.products.barcode,
    activeIngredient: schema.products.activeIngredient,
    manufacturer: schema.products.manufacturerHolder,
    warehouse: schema.warehouses.name,
    prescriptionId: schema.inventoryMovements.prescriptionId,
    saleId: schema.inventoryMovements.saleId,
  })
  .from(schema.inventoryMovements)
  .leftJoin(schema.products, eq(schema.inventoryMovements.productId, schema.products.id))
  .leftJoin(schema.warehouses, eq(schema.inventoryMovements.warehouseId, schema.warehouses.id))
  .where(and(...groupedConds))
  .orderBy(desc(schema.inventoryMovements.createdAt))
  .limit(2000);

const totalsByGroup = await db
  .select({
    grp: schema.inventoryMovements.controlledGroup,
    movs: sql<number>`count(*)`,
    in: sql<number>`coalesce(sum(case when ${schema.inventoryMovements.quantity} > 0 then ${schema.inventoryMovements.quantity} else 0 end), 0)`,
    out: sql<number>`coalesce(sum(case when ${schema.inventoryMovements.quantity} < 0 then ${schema.inventoryMovements.quantity} else 0 end), 0)`,
  })
  .from(schema.inventoryMovements)
  .where(and(...baseConds, sql`${schema.inventoryMovements.controlledGroup} IS NOT NULL`))
  .groupBy(schema.inventoryMovements.controlledGroup);

const fmtDate = (d: Date | null) => d ? new Date(d).toLocaleDateString("es-MX", { dateStyle: "short" }) : "";
const fmtDateTime = (d: Date | null) => d ? new Date(d).toLocaleString("es-MX", { dateStyle: "short", timeStyle: "short" }) : "";

const typeLabels: Record<string, string> = {
  purchase: "Entrada",
  sale: "Venta",
  transfer_in: "Traslado IN",
  transfer_out: "Traslado OUT",
  adjustment_in: "Ajuste +",
  adjustment_out: "Ajuste −",
  expired_loss: "Caducidad",
  return: "Devolución",
};

const groupLabels: Record<string, string> = {
  I: "I · Estupefacientes",
  II: "II · Psicotrópicos A",
  III: "III · Psicotrópicos B",
  IV: "IV · Antibióticos",
};
---

<AppLayout title="Reporte COFEPRIS" activeRoute="cofepris">
  <div class="mx-auto max-w-7xl px-4 py-6 md:px-6 md:py-8 print:py-4">
    <header class="mb-6 flex flex-wrap items-end justify-between gap-4 print:hidden">
      <div>
        <h1 class="font-heading text-2xl font-bold text-neutral-900 md:text-3xl">Libro de control COFEPRIS</h1>
        <p class="mt-1 text-sm text-neutral-500">
          Movimientos de medicamentos Grupos I-IV con balance materializado. Art. 226 LGS.
        </p>
      </div>
      <button onclick="window.print()" class="rounded-lg bg-brand-blue px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-800">
        Imprimir / Guardar PDF
      </button>
    </header>

    <!-- Header de impresión -->
    <div class="mb-6 hidden border-b border-neutral-300 pb-4 print:block">
      <div class="flex items-center justify-between">
        <div class="flex items-center gap-3">
          <img src="/brand/farmalat-isotipo-blue.svg" alt="" class="h-12 w-12" />
          <div>
            <div class="font-heading text-lg font-bold text-neutral-900">Farmacia Alfa Matriz</div>
            <div class="text-xs text-neutral-600">Av. Topo Chico 590-2F, Anáhuac, San Nicolás de los Garza, N.L.</div>
          </div>
        </div>
        <div class="text-right text-xs">
          <div class="font-heading text-base font-bold text-neutral-900">Libro de control - Art. 226 LGS</div>
          <div class="text-neutral-600">Periodo: {fromStr} al {toStr}</div>
          <div class="text-neutral-600">Generado: {new Date().toLocaleString("es-MX")}</div>
        </div>
      </div>
    </div>

    <!-- Filtros -->
    <form method="get" class="mb-6 grid gap-3 rounded-2xl border border-neutral-200 bg-white p-4 shadow-card print:hidden md:grid-cols-[1fr_1fr_1fr_auto]">
      <label class="block">
        <span class="mb-1 block text-xs font-semibold uppercase tracking-wider text-neutral-500">Desde</span>
        <input type="date" name="from" value={fromStr} class="w-full rounded-lg border border-neutral-200 bg-neutral-50 px-3 py-2 text-sm focus:border-blue-300 focus:bg-white focus:outline-none" />
      </label>
      <label class="block">
        <span class="mb-1 block text-xs font-semibold uppercase tracking-wider text-neutral-500">Hasta</span>
        <input type="date" name="to" value={toStr} class="w-full rounded-lg border border-neutral-200 bg-neutral-50 px-3 py-2 text-sm focus:border-blue-300 focus:bg-white focus:outline-none" />
      </label>
      <label class="block">
        <span class="mb-1 block text-xs font-semibold uppercase tracking-wider text-neutral-500">Grupo</span>
        <select name="group" class="w-full rounded-lg border border-neutral-200 bg-neutral-50 px-3 py-2 text-sm focus:border-blue-300 focus:bg-white focus:outline-none">
          <option value="all" selected={group === "all"}>Todos los grupos</option>
          {Object.entries(groupLabels).map(([k, v]) => (<option value={k} selected={group === k}>{v}</option>))}
        </select>
      </label>
      <div class="flex items-end">
        <button type="submit" class="rounded-lg bg-brand-blue px-4 py-2.5 text-sm font-semibold text-white">Aplicar</button>
      </div>
    </form>

    <!-- Totales por grupo -->
    <section class="mb-6 grid gap-4 md:grid-cols-4">
      {(["I","II","III","IV"]).map((g) => {
        const r = totalsByGroup.find((x) => x.grp === g);
        return (
          <Kpi
            label={`Grupo ${g}`}
            value={r ? `${Math.abs(Number(r.out))} salidas` : "Sin movimientos"}
          />
        );
      })}
    </section>

    <!-- Tabla del libro -->
    <div class="overflow-hidden rounded-2xl border border-neutral-200 bg-white shadow-card print:rounded-none print:shadow-none">
      <div class="overflow-x-auto">
        <table class="w-full text-xs">
          <thead class="bg-neutral-50">
            <tr class="text-left text-[10px] font-semibold uppercase tracking-wider text-neutral-500">
              <th class="px-3 py-2">Fecha</th>
              <th class="px-3 py-2 text-center">Grupo</th>
              <th class="px-3 py-2">Producto</th>
              <th class="hidden px-3 py-2 md:table-cell">Principio activo</th>
              <th class="hidden px-3 py-2 lg:table-cell">Titular del registro</th>
              <th class="px-3 py-2 text-center">Movimiento</th>
              <th class="px-3 py-2 text-right">Entrada</th>
              <th class="px-3 py-2 text-right">Salida</th>
              <th class="px-3 py-2 text-right">Saldo</th>
              <th class="hidden px-3 py-2 lg:table-cell">Receta / Folio</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-neutral-100">
            {movs.map((m) => {
              const qty = Number(m.quantity);
              return (
                <tr class="transition hover:bg-blue-50/30">
                  <td class="px-3 py-2 font-mono text-[10px] text-neutral-700">{fmtDateTime(m.createdAt)}</td>
                  <td class="px-3 py-2 text-center">
                    <span class="rounded-full bg-warning-50 px-1.5 py-0.5 font-bold text-warning-500">{m.controlledGroup}</span>
                  </td>
                  <td class="px-3 py-2">
                    <div class="font-medium text-neutral-900">{m.product}</div>
                    <div class="font-mono text-[9px] text-neutral-500">{m.barcode}</div>
                  </td>
                  <td class="hidden px-3 py-2 text-neutral-600 md:table-cell">{m.activeIngredient ?? "—"}</td>
                  <td class="hidden px-3 py-2 text-neutral-600 lg:table-cell">{m.manufacturer ?? "—"}</td>
                  <td class="px-3 py-2 text-center text-neutral-700">{typeLabels[m.type] ?? m.type}</td>
                  <td class="px-3 py-2 text-right font-mono tabular text-success-500">{qty > 0 ? qty : "—"}</td>
                  <td class="px-3 py-2 text-right font-mono tabular text-danger-500">{qty < 0 ? Math.abs(qty) : "—"}</td>
                  <td class="px-3 py-2 text-right font-mono font-bold tabular text-neutral-900">{m.balanceAfter}</td>
                  <td class="hidden px-3 py-2 font-mono text-[10px] text-neutral-500 lg:table-cell">
                    {m.saleId ? `Ticket #${m.saleId}` : m.prescriptionId ? `Receta #${m.prescriptionId}` : "—"}
                  </td>
                </tr>
              );
            })}
            {movs.length === 0 && (
              <tr><td colspan="10" class="px-5 py-16 text-center text-sm text-neutral-400">Sin movimientos de productos controlados en el rango.</td></tr>
            )}
          </tbody>
        </table>
      </div>
    </div>

    <p class="mt-6 text-[10px] leading-relaxed text-neutral-500 print:mt-8">
      Documento generado por FarmaLat sobre la base de los movimientos registrados en el sistema. Este reporte materializa el saldo
      por cada movimiento conforme al Suplemento FEUM para establecimientos. La conservación física del libro foliado autorizado por
      COFEPRIS sigue siendo responsabilidad del titular del establecimiento.
    </p>
  </div>
</AppLayout>

<style is:inline>
  @media print {
    @page { size: legal landscape; margin: 12mm; }
    body { background: white; }
    aside, header.sticky, header.flex.h-14, .no-print { display: none !important; }
  }
</style>
