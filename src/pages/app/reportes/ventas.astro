---
export const prerender = false;
import AppLayout from "../../../layouts/AppLayout.astro";
import Kpi from "../../../components/Kpi.astro";
import { getDb, schema } from "../../../lib/db";
import { and, eq, gte, lte, sql, desc } from "drizzle-orm";

const db = getDb();
const tenantId = Astro.locals.tenantId;

const today = new Date(); today.setHours(23, 59, 59, 999);
const monthAgo = new Date(today); monthAgo.setDate(monthAgo.getDate() - 30); monthAgo.setHours(0, 0, 0, 0);

const fromStr = Astro.url.searchParams.get("from") ?? monthAgo.toISOString().slice(0, 10);
const toStr = Astro.url.searchParams.get("to") ?? today.toISOString().slice(0, 10);
const fromTs = new Date(fromStr + "T00:00:00").getTime();
const toTs = new Date(toStr + "T23:59:59.999").getTime();

// Resumen agregado
const summary = await db
  .select({
    n: sql<number>`count(distinct ${schema.sales.id})`,
    units: sql<number>`coalesce(sum(${schema.saleItems.quantity}), 0)`,
    subtotal: sql<number>`coalesce(sum(${schema.sales.subtotal}), 0)`,
    iva: sql<number>`coalesce(sum(${schema.sales.ivaTotal}), 0)`,
    total: sql<number>`coalesce(sum(${schema.sales.total}), 0)`,
  })
  .from(schema.sales)
  .leftJoin(schema.saleItems, eq(schema.saleItems.saleId, schema.sales.id))
  .where(
    and(
      eq(schema.sales.tenantId, tenantId),
      eq(schema.sales.status, "completed"),
      gte(schema.sales.createdAt, new Date(fromTs)),
      lte(schema.sales.createdAt, new Date(toTs)),
    ),
  );
const s = summary[0] ?? { n: 0, units: 0, subtotal: 0, iva: 0, total: 0 };

// Top productos
const top = await db
  .select({
    name: schema.saleItems.productName,
    qty: sql<number>`coalesce(sum(${schema.saleItems.quantity}), 0)`,
    revenue: sql<number>`coalesce(sum(${schema.saleItems.total}), 0)`,
  })
  .from(schema.saleItems)
  .leftJoin(schema.sales, eq(schema.saleItems.saleId, schema.sales.id))
  .where(
    and(
      eq(schema.sales.tenantId, tenantId),
      eq(schema.sales.status, "completed"),
      gte(schema.sales.createdAt, new Date(fromTs)),
      lte(schema.sales.createdAt, new Date(toTs)),
    ),
  )
  .groupBy(schema.saleItems.productName)
  .orderBy(desc(sql`sum(${schema.saleItems.total})`))
  .limit(20);

// Por dia
const dayExpr = sql<string>`date(${schema.sales.createdAt} / 1000, 'unixepoch', 'localtime')`;
const byDay = await db
  .select({
    day: dayExpr,
    n: sql<number>`count(*)`,
    total: sql<number>`coalesce(sum(${schema.sales.total}), 0)`,
  })
  .from(schema.sales)
  .where(
    and(
      eq(schema.sales.tenantId, tenantId),
      eq(schema.sales.status, "completed"),
      gte(schema.sales.createdAt, new Date(fromTs)),
      lte(schema.sales.createdAt, new Date(toTs)),
    ),
  )
  .groupBy(dayExpr)
  .orderBy(desc(dayExpr))
  .limit(60);

const fmt = (n: number) => "$" + Number(n).toLocaleString("es-MX", { minimumFractionDigits: 2, maximumFractionDigits: 2 });
const maxDayTotal = Math.max(1, ...byDay.map((b) => Number(b.total)));
---

<AppLayout title="Reporte de ventas" activeRoute="ventas-rep">
  <div class="mx-auto max-w-7xl px-4 py-6 md:px-6 md:py-8">
    <header class="mb-6 flex flex-wrap items-end justify-between gap-4">
      <div>
        <h1 class="font-heading text-2xl font-bold text-neutral-900 md:text-3xl">Reporte de ventas</h1>
        <p class="mt-1 text-sm text-neutral-500">Del {fromStr} al {toStr}</p>
      </div>
    </header>

    <form method="get" class="mb-6 grid gap-3 rounded-2xl border border-neutral-200 bg-white p-4 shadow-card sm:grid-cols-[1fr_1fr_auto]">
      <label class="block">
        <span class="mb-1 block text-xs font-semibold uppercase tracking-wider text-neutral-500">Desde</span>
        <input type="date" name="from" value={fromStr} class="w-full rounded-lg border border-neutral-200 bg-neutral-50 px-3 py-2 text-sm focus:border-blue-300 focus:bg-white focus:outline-none" />
      </label>
      <label class="block">
        <span class="mb-1 block text-xs font-semibold uppercase tracking-wider text-neutral-500">Hasta</span>
        <input type="date" name="to" value={toStr} class="w-full rounded-lg border border-neutral-200 bg-neutral-50 px-3 py-2 text-sm focus:border-blue-300 focus:bg-white focus:outline-none" />
      </label>
      <div class="flex items-end">
        <button type="submit" class="rounded-lg bg-brand-blue px-4 py-2.5 text-sm font-semibold text-white">Aplicar</button>
      </div>
    </form>

    <section class="mb-6 grid gap-4 md:grid-cols-4">
      <Kpi label="Tickets" value={String(s.n)} />
      <Kpi label="Unidades vendidas" value={Number(s.units).toLocaleString("es-MX")} />
      <Kpi label="Subtotal" value={fmt(Number(s.subtotal))} mono />
      <Kpi label="Total ingresos" value={fmt(Number(s.total))} primary mono />
    </section>

    <div class="grid gap-6 lg:grid-cols-2">
      <!-- Top productos -->
      <section class="rounded-2xl border border-neutral-200 bg-white shadow-card">
        <header class="border-b border-neutral-200 px-5 py-4">
          <h2 class="font-heading text-lg font-bold text-neutral-900">Top productos</h2>
          <p class="text-xs text-neutral-500">Por ingresos generados</p>
        </header>
        <ol class="divide-y divide-neutral-100">
          {top.map((t, i) => (
            <li class="flex items-center gap-3 px-5 py-3">
              <span class="flex h-7 w-7 flex-none items-center justify-center rounded-full bg-blue-50 font-mono text-xs font-bold text-brand-blue">{i + 1}</span>
              <div class="min-w-0 flex-1">
                <div class="truncate text-sm font-medium text-neutral-900">{t.name}</div>
                <div class="text-xs text-neutral-500">{Number(t.qty)} unidades</div>
              </div>
              <div class="flex-none text-right font-mono text-sm font-semibold tabular text-neutral-900">{fmt(Number(t.revenue))}</div>
            </li>
          ))}
          {top.length === 0 && <li class="px-5 py-8 text-center text-sm text-neutral-400">Sin ventas en el rango</li>}
        </ol>
      </section>

      <!-- Ventas por día -->
      <section class="rounded-2xl border border-neutral-200 bg-white shadow-card">
        <header class="border-b border-neutral-200 px-5 py-4">
          <h2 class="font-heading text-lg font-bold text-neutral-900">Ventas por día</h2>
          <p class="text-xs text-neutral-500">Últimos 60 días con ventas</p>
        </header>
        <div class="divide-y divide-neutral-100">
          {byDay.map((b) => (
            <div class="flex items-center gap-3 px-5 py-2">
              <div class="w-20 flex-none font-mono text-xs text-neutral-500">{b.day}</div>
              <div class="flex-1">
                <div class="h-2 rounded-full bg-neutral-100">
                  <div class="h-2 rounded-full bg-brand-blue" style={`width: ${(Number(b.total) / maxDayTotal) * 100}%`}></div>
                </div>
              </div>
              <div class="w-12 flex-none text-right text-xs text-neutral-500">{b.n}</div>
              <div class="w-24 flex-none text-right font-mono text-xs font-semibold tabular text-neutral-900">{fmt(Number(b.total))}</div>
            </div>
          ))}
          {byDay.length === 0 && <div class="px-5 py-8 text-center text-sm text-neutral-400">Sin datos en el rango</div>}
        </div>
      </section>
    </div>
  </div>
</AppLayout>

<style is:inline>
  .Kpi { /* placeholder para futuras animaciones */ }
</style>
