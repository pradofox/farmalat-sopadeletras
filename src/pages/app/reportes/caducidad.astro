---
export const prerender = false;
import AppLayout from "../../../layouts/AppLayout.astro";
import Kpi from "../../../components/Kpi.astro";
import { getDb, schema } from "../../../lib/db";
import { and, eq, gt, lte, sql } from "drizzle-orm";

const db = getDb();
const tenantId = Astro.locals.tenantId;

const days = Number(Astro.url.searchParams.get("d") ?? 90);
const horizon = new Date(); horizon.setDate(horizon.getDate() + days);
const now = new Date();

const lots = await db
  .select({
    id: schema.productLots.id,
    lot: schema.productLots.lot,
    expiryDate: schema.productLots.expiryDate,
    qtyOnHand: schema.productLots.qtyOnHand,
    unitCost: schema.productLots.unitCost,
    productName: schema.products.name,
    barcode: schema.products.barcode,
    warehouse: schema.warehouses.name,
  })
  .from(schema.productLots)
  .leftJoin(schema.products, eq(schema.productLots.productId, schema.products.id))
  .leftJoin(schema.warehouses, eq(schema.productLots.warehouseId, schema.warehouses.id))
  .where(
    and(
      eq(schema.productLots.tenantId, tenantId),
      gt(schema.productLots.qtyOnHand, 0),
      lte(schema.productLots.expiryDate, horizon),
    ),
  )
  .orderBy(schema.productLots.expiryDate)
  .limit(500);

const expired = lots.filter((l) => l.expiryDate && new Date(l.expiryDate) < now);
const soon = lots.filter((l) => l.expiryDate && new Date(l.expiryDate) >= now);

const fmt = (n: number) => "$" + Number(n).toLocaleString("es-MX", { minimumFractionDigits: 2 });
const fmtDate = (d: Date | null) => d ? new Date(d).toLocaleDateString("es-MX", { dateStyle: "medium" }) : "—";
const daysUntil = (d: Date | null) => {
  if (!d) return null;
  const ms = new Date(d).getTime() - now.getTime();
  return Math.ceil(ms / (1000 * 60 * 60 * 24));
};

const totalAtRisk = lots.reduce((a, l) => a + Number(l.qtyOnHand) * Number(l.unitCost), 0);
---

<AppLayout title="Caducidad" activeRoute="">
  <div class="mx-auto max-w-7xl px-4 py-6 md:px-6 md:py-8">
    <header class="mb-6 flex flex-wrap items-end justify-between gap-4">
      <div>
        <h1 class="font-heading text-2xl font-bold text-neutral-900 md:text-3xl">Productos por caducar</h1>
        <p class="mt-1 text-sm text-neutral-500">Lotes con caducidad en los próximos {days} días o ya caducados</p>
      </div>
      <div class="flex gap-2">
        {[30, 60, 90, 180].map((d) => (
          <a href={`?d=${d}`} class={`rounded-lg border px-3 py-1.5 text-sm font-medium ${days === d ? "border-brand-blue bg-blue-50 text-brand-blue" : "border-neutral-200 bg-white text-neutral-600 hover:bg-neutral-50"}`}>{d} días</a>
        ))}
      </div>
    </header>

    <section class="mb-6 grid gap-4 md:grid-cols-3">
      <Kpi label="Ya caducados" value={String(expired.length)} />
      <Kpi label="Por caducar" value={String(soon.length)} />
      <Kpi label="Valor en riesgo a costo" value={fmt(totalAtRisk)} mono primary />
    </section>

    <div class="overflow-hidden rounded-2xl border border-neutral-200 bg-white shadow-card">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-neutral-50">
            <tr class="text-left text-xs font-semibold uppercase tracking-wider text-neutral-500">
              <th class="px-4 py-3 md:px-5">Producto</th>
              <th class="px-4 py-3 md:px-5">Lote</th>
              <th class="px-4 py-3 md:px-5">Caduca</th>
              <th class="hidden px-4 py-3 md:table-cell md:px-5">Sucursal</th>
              <th class="px-4 py-3 text-right md:px-5">Existencia</th>
              <th class="hidden px-4 py-3 text-right md:table-cell md:px-5">Valor a costo</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-neutral-100">
            {lots.map((l) => {
              const d = daysUntil(l.expiryDate);
              const isExpired = d !== null && d < 0;
              return (
                <tr class={`transition ${isExpired ? "bg-danger-50/40" : ""} hover:bg-blue-50/40`}>
                  <td class="px-4 py-3 md:px-5">
                    <div class="font-medium text-neutral-900">{l.productName}</div>
                    <div class="font-mono text-[10px] text-neutral-500">{l.barcode}</div>
                  </td>
                  <td class="px-4 py-3 font-mono text-xs text-neutral-700 md:px-5">{l.lot}</td>
                  <td class="px-4 py-3 md:px-5">
                    <span class={`font-mono text-sm font-semibold ${isExpired ? "text-danger-500" : d !== null && d < 30 ? "text-warning-500" : "text-neutral-700"}`}>{fmtDate(l.expiryDate)}</span>
                    {d !== null && (
                      <div class="text-[10px] text-neutral-500">{isExpired ? `Caducó hace ${-d} días` : `Caduca en ${d} días`}</div>
                    )}
                  </td>
                  <td class="hidden px-4 py-3 text-neutral-600 md:table-cell md:px-5">{l.warehouse ?? "—"}</td>
                  <td class="px-4 py-3 text-right font-mono font-semibold tabular text-neutral-900 md:px-5">{l.qtyOnHand}</td>
                  <td class="hidden px-4 py-3 text-right font-mono tabular text-neutral-700 md:table-cell md:px-5">{fmt(Number(l.qtyOnHand) * Number(l.unitCost))}</td>
                </tr>
              );
            })}
            {lots.length === 0 && (
              <tr><td colspan="6" class="px-5 py-16 text-center text-sm text-success-500">Sin lotes próximos a caducar en {days} días.</td></tr>
            )}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</AppLayout>
