---
export const prerender = false;
import AppLayout from "../../layouts/AppLayout.astro";
import { getDb } from "../../lib/db";
import { schema } from "../../lib/db";
import { eq, like, or, and, sql } from "drizzle-orm";

const db = getDb();
const tenantId = Astro.locals.tenantId;

const q = (Astro.url.searchParams.get("q") ?? "").trim();

const where = q
  ? and(
      eq(schema.products.tenantId, tenantId),
      or(like(schema.products.name, `%${q}%`), like(schema.products.barcode, `%${q}%`)),
    )
  : eq(schema.products.tenantId, tenantId);

const products = await db
  .select({
    id: schema.products.id,
    name: schema.products.name,
    barcode: schema.products.barcode,
    publicPrice: schema.products.publicPrice,
    cost: schema.products.cost,
    ivaPct: schema.products.ivaPct,
    controlledGroup: schema.products.controlledGroup,
    requiresPrescription: schema.products.requiresPrescription,
    isAntibiotic: schema.products.isAntibiotic,
    department: schema.departments.name,
  })
  .from(schema.products)
  .leftJoin(schema.departments, eq(schema.products.departmentId, schema.departments.id))
  .where(where)
  .orderBy(schema.products.name)
  .limit(200);

const countResult = await db
  .select({ n: sql<number>`count(*)` })
  .from(schema.products)
  .where(eq(schema.products.tenantId, tenantId));
const totalProducts = countResult[0]?.n ?? 0;

const fmt = (n: number) => "$" + n.toLocaleString("es-MX", { minimumFractionDigits: 2, maximumFractionDigits: 2 });

const badgeForGroup = (g: string | null) => {
  if (!g) return null;
  const labels: Record<string, { label: string; cls: string }> = {
    I:   { label: "I · Estupefaciente",   cls: "bg-danger-50 text-danger-500" },
    II:  { label: "II · Psicotrópico A",  cls: "bg-danger-50 text-danger-500" },
    III: { label: "III · Psicotrópico B", cls: "bg-warning-50 text-warning-500" },
    IV:  { label: "IV · Antibiótico",     cls: "bg-orange-50 text-orange-700" },
    V:   { label: "V · Libre venta",      cls: "bg-blue-50 text-brand-blue" },
  };
  return labels[g];
};
---

<AppLayout title="Productos" activeRoute="productos">
  <div class="mx-auto max-w-7xl px-4 py-6 md:px-6 md:py-8">
    <header class="mb-6 flex flex-wrap items-end justify-between gap-4">
      <div>
        <h1 class="font-heading text-2xl font-bold text-neutral-900 md:text-3xl">Productos</h1>
        <p class="mt-1 text-sm text-neutral-500">
          {totalProducts} {totalProducts === 1 ? "producto" : "productos"} en el catálogo
        </p>
      </div>
      <div class="flex flex-wrap gap-2">
        <a
          href="/api/exports/products"
          class="rounded-lg border border-neutral-200 bg-white px-4 py-2 text-sm font-medium text-neutral-700 transition hover:bg-neutral-50"
        >
          Exportar Excel
        </a>
        <a
          href="/app/productos/importar"
          class="rounded-lg border border-neutral-200 bg-white px-4 py-2 text-sm font-medium text-neutral-700 transition hover:bg-neutral-50"
        >
          Importar Excel
        </a>
        <a
          href="/app/productos/nuevo"
          class="rounded-lg bg-brand-blue px-4 py-2 text-sm font-semibold text-white shadow-sm transition hover:bg-blue-800"
        >
          + Nuevo producto
        </a>
      </div>
    </header>

    <form method="get" class="mb-4">
      <div class="relative max-w-xl">
        <svg class="pointer-events-none absolute left-3 top-1/2 h-4 w-4 -translate-y-1/2 text-neutral-400" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="7"/>
          <path d="M21 21l-4-4"/>
        </svg>
        <input
          name="q"
          type="search"
          value={q}
          placeholder="Buscar por nombre o código de barras"
          class="w-full rounded-lg border border-neutral-200 bg-white py-2.5 pl-10 pr-3 text-sm placeholder:text-neutral-400 focus:border-blue-300 focus:outline-none"
          autofocus
        />
      </div>
    </form>

    <div class="overflow-hidden rounded-2xl border border-neutral-200 bg-white shadow-card">
      <div class="overflow-x-auto">
        <table class="w-full text-sm">
          <thead class="bg-neutral-50">
            <tr class="text-left text-xs font-semibold uppercase tracking-wider text-neutral-500">
              <th class="px-4 py-3 md:px-5">Producto</th>
              <th class="px-4 py-3 md:px-5">Código de barras</th>
              <th class="hidden px-4 py-3 md:table-cell md:px-5">Departamento</th>
              <th class="hidden px-4 py-3 lg:table-cell lg:px-5">Clasificación</th>
              <th class="px-4 py-3 text-right md:px-5">Precio</th>
              <th class="hidden px-4 py-3 text-right md:table-cell md:px-5">Costo</th>
              <th class="hidden px-4 py-3 text-right md:table-cell md:px-5">IVA</th>
              <th class="w-12"></th>
            </tr>
          </thead>
          <tbody class="divide-y divide-neutral-100">
            {products.map((p) => {
              const badge = badgeForGroup(p.controlledGroup);
              return (
                <tr class="transition hover:bg-blue-50/40">
                  <td class="px-4 py-3 md:px-5">
                    <div class="font-medium text-neutral-900">{p.name}</div>
                    {p.requiresPrescription && (
                      <span class="mt-1 inline-block text-[10px] font-semibold uppercase tracking-wider text-warning-500">
                        Requiere receta
                      </span>
                    )}
                  </td>
                  <td class="px-4 py-3 font-mono text-xs text-neutral-600 md:px-5">{p.barcode ?? "—"}</td>
                  <td class="hidden px-4 py-3 text-neutral-600 md:table-cell md:px-5">{p.department ?? "—"}</td>
                  <td class="hidden px-4 py-3 lg:table-cell lg:px-5">
                    {badge ? (
                      <span class={`inline-block rounded-full px-2 py-0.5 text-[10px] font-semibold ${badge.cls}`}>
                        {badge.label}
                      </span>
                    ) : (
                      <span class="text-xs text-neutral-400">—</span>
                    )}
                  </td>
                  <td class="px-4 py-3 text-right font-mono font-semibold tabular text-neutral-900 md:px-5">{fmt(p.publicPrice)}</td>
                  <td class="hidden px-4 py-3 text-right font-mono text-xs tabular text-neutral-500 md:table-cell md:px-5">{fmt(p.cost)}</td>
                  <td class="hidden px-4 py-3 text-right text-xs text-neutral-500 md:table-cell md:px-5">{p.ivaPct === 0 ? "0%" : `${p.ivaPct}%`}</td>
                  <td class="px-2 py-3">
                    <a href={`/app/productos/${p.id}`} class="rounded p-1 text-neutral-400 transition hover:bg-blue-50 hover:text-brand-blue" aria-label="Editar">
                      <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round">
                        <path d="M11 4h-7v16h16v-7M18 2l4 4-10 10h-4v-4z"/>
                      </svg>
                    </a>
                  </td>
                </tr>
              );
            })}
            {products.length === 0 && (
              <tr>
                <td colspan="8" class="px-5 py-16 text-center">
                  <div class="text-neutral-400">
                    {q ? `Sin resultados para "${q}".` : "No hay productos cargados."}
                  </div>
                  {totalProducts === 0 && (
                    <form method="post" action="/api/seed" class="mt-4">
                      <button type="submit" class="rounded-lg bg-brand-blue px-4 py-2 text-sm font-semibold text-white">
                        Cargar productos de ejemplo
                      </button>
                    </form>
                  )}
                </td>
              </tr>
            )}
          </tbody>
        </table>
      </div>
    </div>
  </div>
</AppLayout>
