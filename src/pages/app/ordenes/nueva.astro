---
export const prerender = false;
import AppLayout from "../../../layouts/AppLayout.astro";
import SupplierOrderBuilder from "../../../components/SupplierOrderBuilder";
import { getDb, schema } from "../../../lib/db";
import { eq } from "drizzle-orm";

const db = getDb();
const tenantId = Astro.locals.tenantId;
const suppliers = await db.select({ id: schema.suppliers.id, name: schema.suppliers.name })
  .from(schema.suppliers).where(eq(schema.suppliers.tenantId, tenantId)).orderBy(schema.suppliers.name);
const warehouses = await db.select({ id: schema.warehouses.id, name: schema.warehouses.name })
  .from(schema.warehouses).where(eq(schema.warehouses.tenantId, tenantId));
---

<AppLayout title="Nueva orden" activeRoute="ordenes">
  <div class="mx-auto max-w-5xl px-4 py-6 md:px-6 md:py-8">
    <header class="mb-6">
      <a href="/app/ordenes" class="inline-flex items-center gap-2 text-sm font-semibold text-brand-blue hover:underline">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Volver a órdenes
      </a>
      <h1 class="mt-3 font-heading text-2xl font-bold text-neutral-900 md:text-3xl">Nueva orden a proveedor</h1>
    </header>
    {suppliers.length === 0 ? (
      <div class="rounded-2xl border border-warning-500 bg-warning-50 p-6 text-sm text-warning-500">
        Primero da de alta al menos un <a href="/app/proveedores/nuevo" class="font-semibold underline">proveedor</a>.
      </div>
    ) : (
      <SupplierOrderBuilder client:load suppliers={suppliers} warehouses={warehouses} />
    )}
  </div>
</AppLayout>
