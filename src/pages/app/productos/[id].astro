---
export const prerender = false;
import AppLayout from "../../../layouts/AppLayout.astro";
import ProductForm from "../../../components/ProductForm";
import { getDb, schema } from "../../../lib/db";
import { and, eq } from "drizzle-orm";

const db = getDb();
const tenantId = Astro.locals.tenantId;
const id = Number(Astro.params.id);

const [product] = await db
  .select()
  .from(schema.products)
  .where(and(eq(schema.products.id, id), eq(schema.products.tenantId, tenantId)))
  .limit(1);

if (!product) return Astro.redirect("/app/productos");

const departments = await db.select({ id: schema.departments.id, name: schema.departments.name }).from(schema.departments).where(eq(schema.departments.tenantId, tenantId));
const units = await db.select({ id: schema.units.id, name: schema.units.name, abbreviation: schema.units.abbreviation }).from(schema.units).where(eq(schema.units.tenantId, tenantId));
---

<AppLayout title={product.name} activeRoute="productos">
  <div class="mx-auto max-w-4xl px-4 py-6 md:px-6 md:py-8">
    <header class="mb-6">
      <a href="/app/productos" class="inline-flex items-center gap-2 text-sm font-semibold text-brand-blue hover:underline">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Volver a productos
      </a>
      <h1 class="mt-3 font-heading text-2xl font-bold text-neutral-900 md:text-3xl">{product.name}</h1>
      <p class="mt-1 font-mono text-xs text-neutral-500">{product.barcode ?? ""}</p>
    </header>
    <ProductForm client:load product={product} departments={departments} units={units} />
  </div>
</AppLayout>
