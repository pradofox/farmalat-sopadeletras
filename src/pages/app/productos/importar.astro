---
export const prerender = false;
import AppLayout from "../../../layouts/AppLayout.astro";
import ImportProducts from "../../../components/ImportProducts";
---

<AppLayout title="Importar productos" activeRoute="productos">
  <div class="mx-auto max-w-4xl px-4 py-6 md:px-6 md:py-8">
    <header class="mb-6">
      <a href="/app/productos" class="inline-flex items-center gap-2 text-sm font-semibold text-brand-blue hover:underline">
        <svg class="h-4 w-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><path d="M19 12H5M12 19l-7-7 7-7"/></svg>
        Volver a productos
      </a>
      <h1 class="mt-3 font-heading text-2xl font-bold text-neutral-900 md:text-3xl">Importar catálogo</h1>
      <p class="mt-1 text-sm text-neutral-500">
        Sube un Excel o CSV exportado de tu sistema actual. Detectamos automáticamente las columnas.
      </p>
    </header>
    <ImportProducts client:load />
  </div>
</AppLayout>
