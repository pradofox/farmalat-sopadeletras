---
export const prerender = false;
import AppLayout from "../../layouts/AppLayout.astro";
import { getDb, schema } from "../../lib/db";
import { eq, desc } from "drizzle-orm";

const db = getDb();
const tenantId = Astro.locals.tenantId;

const accounts = await db
  .select({
    id: schema.patientAccounts.id,
    accountNumber: schema.patientAccounts.accountNumber,
    status: schema.patientAccounts.status,
    payerType: schema.patientAccounts.payerType,
    bedNumber: schema.patientAccounts.bedNumber,
    admittedAt: schema.patientAccounts.admittedAt,
    dischargedAt: schema.patientAccounts.dischargedAt,
    totalCharged: schema.patientAccounts.totalCharged,
    patient: schema.patients.fullName,
    warehouse: schema.warehouses.name,
  })
  .from(schema.patientAccounts)
  .leftJoin(schema.patients, eq(schema.patientAccounts.patientId, schema.patients.id))
  .leftJoin(schema.warehouses, eq(schema.patientAccounts.warehouseId, schema.warehouses.id))
  .where(eq(schema.patientAccounts.tenantId, tenantId))
  .orderBy(desc(schema.patientAccounts.createdAt))
  .limit(300);

const open = accounts.filter((a) => a.status === "open");
const closed = accounts.filter((a) => a.status === "closed");

const fmt = (n: number) => "$" + Number(n).toLocaleString("es-MX", { minimumFractionDigits: 2 });
const fmtDate = (d: Date | null) => d ? new Date(d).toLocaleDateString("es-MX", { dateStyle: "medium" }) : "—";
const payerLabel: Record<string, string> = { private: "Particular", insurance: "Aseguradora", imss: "IMSS", issste: "ISSSTE", other: "Otro" };
---

<AppLayout title="Cuentas-paciente" activeRoute="">
  <div class="mx-auto max-w-7xl px-4 py-6 md:px-6 md:py-8">
    <header class="mb-6 flex flex-wrap items-end justify-between gap-4">
      <div>
        <h1 class="font-heading text-2xl font-bold text-neutral-900 md:text-3xl">Cuentas-paciente</h1>
        <p class="mt-1 text-sm text-neutral-500">
          Farmacia hospitalaria. {open.length} abiertas · {closed.length} cerradas.
        </p>
      </div>
      <a href="/app/cuentas-paciente/nueva" class="rounded-lg bg-brand-blue px-4 py-2 text-sm font-semibold text-white shadow-sm hover:bg-blue-800">+ Abrir cuenta</a>
    </header>

    {open.length > 0 && (
      <section class="mb-8">
        <h2 class="mb-3 font-heading text-base font-bold text-neutral-700">Abiertas</h2>
        <div class="grid gap-4 md:grid-cols-2 lg:grid-cols-3">
          {open.map((a) => (
            <a href={`/app/cuentas-paciente/${a.id}`} class="block rounded-2xl border-2 border-warning-500/40 bg-white p-5 shadow-card transition hover:border-warning-500 hover:shadow-lg">
              <div class="flex items-start justify-between gap-2">
                <div>
                  <div class="font-mono text-xs font-semibold text-warning-500">{a.accountNumber}</div>
                  <div class="mt-1 font-heading text-base font-bold text-neutral-900">{a.patient}</div>
                  {a.bedNumber && <div class="text-xs text-neutral-500">Cama {a.bedNumber}</div>}
                </div>
                <span class="rounded-full bg-warning-50 px-2 py-0.5 text-[10px] font-bold uppercase tracking-wider text-warning-500">Abierta</span>
              </div>
              <div class="mt-4 grid grid-cols-2 gap-2 text-xs">
                <div>
                  <div class="text-neutral-500">Ingresó</div>
                  <div class="font-mono font-semibold text-neutral-900">{fmtDate(a.admittedAt)}</div>
                </div>
                <div>
                  <div class="text-neutral-500">Pagador</div>
                  <div class="font-semibold text-neutral-900">{payerLabel[a.payerType] ?? a.payerType}</div>
                </div>
              </div>
              <div class="mt-4 flex items-center justify-between border-t border-neutral-100 pt-3">
                <span class="text-xs text-neutral-500">Acumulado</span>
                <span class="font-mono text-xl font-bold tabular text-brand-blue">{fmt(a.totalCharged)}</span>
              </div>
            </a>
          ))}
        </div>
      </section>
    )}

    {closed.length > 0 && (
      <section>
        <h2 class="mb-3 font-heading text-base font-bold text-neutral-700">Cerradas recientes</h2>
        <div class="overflow-hidden rounded-2xl border border-neutral-200 bg-white shadow-card">
          <div class="overflow-x-auto">
            <table class="w-full text-sm">
              <thead class="bg-neutral-50">
                <tr class="text-left text-xs font-semibold uppercase tracking-wider text-neutral-500">
                  <th class="px-4 py-3 md:px-5">Cuenta</th>
                  <th class="px-4 py-3 md:px-5">Paciente</th>
                  <th class="hidden px-4 py-3 md:table-cell md:px-5">Ingresó</th>
                  <th class="hidden px-4 py-3 md:table-cell md:px-5">Alta</th>
                  <th class="hidden px-4 py-3 lg:table-cell lg:px-5">Pagador</th>
                  <th class="px-4 py-3 text-right md:px-5">Total</th>
                </tr>
              </thead>
              <tbody class="divide-y divide-neutral-100">
                {closed.map((a) => (
                  <tr class="cursor-pointer transition hover:bg-blue-50/40" onclick={`window.location='/app/cuentas-paciente/${a.id}'`}>
                    <td class="px-4 py-3 font-mono text-xs text-neutral-700 md:px-5">{a.accountNumber}</td>
                    <td class="px-4 py-3 font-medium text-neutral-900 md:px-5">{a.patient}</td>
                    <td class="hidden px-4 py-3 text-neutral-600 md:table-cell md:px-5">{fmtDate(a.admittedAt)}</td>
                    <td class="hidden px-4 py-3 text-neutral-600 md:table-cell md:px-5">{fmtDate(a.dischargedAt)}</td>
                    <td class="hidden px-4 py-3 text-neutral-600 lg:table-cell lg:px-5">{payerLabel[a.payerType] ?? a.payerType}</td>
                    <td class="px-4 py-3 text-right font-mono font-semibold tabular text-neutral-900 md:px-5">{fmt(a.totalCharged)}</td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        </div>
      </section>
    )}

    {accounts.length === 0 && (
      <div class="rounded-3xl border border-neutral-200 bg-white p-12 text-center shadow-card">
        <div class="mx-auto mb-6 flex h-16 w-16 items-center justify-center rounded-2xl bg-blue-50">
          <svg class="h-8 w-8 text-brand-blue" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6"><path d="M19 21V8l-7-5-7 5v13M9 22V12h6v10" stroke-linecap="round" stroke-linejoin="round" /></svg>
        </div>
        <h2 class="font-heading text-xl font-bold text-neutral-900">Aún no hay cuentas abiertas</h2>
        <p class="mx-auto mt-2 max-w-md text-sm text-neutral-500">
          El módulo de cuentas-paciente es para farmacia hospitalaria. Acumula consumos por paciente durante su estancia y los cobra al alta.
        </p>
        <a href="/app/cuentas-paciente/nueva" class="mt-6 inline-block rounded-lg bg-brand-blue px-5 py-2.5 text-sm font-semibold text-white">Abrir primera cuenta</a>
      </div>
    )}
  </div>
</AppLayout>
