---
export const prerender = false;
import "../../../../styles/global.css";
import { getDb, schema } from "../../../../lib/db";
import { and, eq } from "drizzle-orm";

const db = getDb();
const slug = Astro.params.slug as string;
const folio = Astro.params.folio as string;

const [tenant] = await db.select().from(schema.tenants).where(eq(schema.tenants.slug, slug)).limit(1);
if (!tenant) return new Response("Not found", { status: 404 });

const [sale] = await db.select().from(schema.sales)
  .where(and(eq(schema.sales.tenantId, tenant.id), eq(schema.sales.ticketNumber, folio)))
  .limit(1);
if (!sale || sale.cfdiStatus !== "issued") return Astro.redirect(`/f/${slug}/${folio}`);

const items = await db.select().from(schema.saleItems).where(eq(schema.saleItems.saleId, sale.id));
const [customer] = sale.customerId ? await db.select().from(schema.customers).where(eq(schema.customers.id, sale.customerId)).limit(1) : [null];

const fmt = (n: number) => "$" + Number(n).toLocaleString("es-MX", { minimumFractionDigits: 2 });
---

<!doctype html>
<html lang="es-MX">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link href="https://fonts.googleapis.com/css2?family=Nunito:wght@600;700&family=Inter:wght@400;500;600&family=JetBrains+Mono:wght@500&display=swap" rel="stylesheet" />
    <title>Factura {sale.cfdiUuid} · {tenant.name}</title>
  </head>
  <body class="min-h-screen bg-neutral-50 antialiased">
    <main class="mx-auto max-w-3xl px-4 py-8 md:px-6 md:py-12">
      <div class="rounded-2xl border border-success-500 bg-success-50 p-6 text-center">
        <h1 class="font-heading text-xl font-bold text-success-500">Factura emitida</h1>
        <p class="mt-1 text-sm text-neutral-700">UUID <span class="font-mono">{sale.cfdiUuid}</span></p>
        <p class="mt-2 text-[11px] text-warning-500">⚠ Esta es una factura MOCK (sin timbrar). Sistema en pruebas.</p>
      </div>

      <section class="mt-6 rounded-2xl border border-neutral-200 bg-white p-6 shadow-card">
        <div class="flex items-start justify-between gap-4">
          <div>
            <img src="/brand/farmalat-isotipo-blue.svg" alt="" class="h-10 w-10" />
            <h2 class="mt-2 font-heading text-base font-bold text-neutral-900">{tenant.name}</h2>
            <p class="text-xs text-neutral-500">RFC: {tenant.rfc ?? "—"}</p>
            <p class="text-xs text-neutral-500">{tenant.regimenFiscal ?? "—"}</p>
          </div>
          <div class="text-right">
            <div class="font-mono text-xs text-neutral-500">Folio</div>
            <div class="font-mono text-base font-bold text-neutral-900">{sale.ticketNumber}</div>
          </div>
        </div>

        {customer && (
          <div class="mt-6 rounded-lg bg-neutral-50 p-4 text-sm">
            <div class="text-xs uppercase tracking-wider text-neutral-500">Receptor</div>
            <div class="mt-1 font-semibold text-neutral-900">{customer.name}</div>
            <div class="font-mono text-xs text-neutral-700">RFC {customer.rfc} · {customer.taxRegime} · CP {customer.zipCode}</div>
            <div class="text-xs text-neutral-500">Uso CFDI: {customer.cfdiUse}</div>
          </div>
        )}

        <table class="mt-6 w-full text-sm">
          <thead>
            <tr class="border-b border-neutral-200 text-left text-xs font-semibold uppercase tracking-wider text-neutral-500">
              <th class="py-2 text-center">Cant.</th>
              <th class="py-2">Concepto</th>
              <th class="py-2 text-right">Precio</th>
              <th class="py-2 text-right">Importe</th>
            </tr>
          </thead>
          <tbody class="divide-y divide-neutral-100">
            {items.map((it) => (
              <tr>
                <td class="py-2 text-center font-mono">{it.quantity}</td>
                <td class="py-2 text-neutral-900">{it.productName}</td>
                <td class="py-2 text-right font-mono">{fmt(it.unitPrice)}</td>
                <td class="py-2 text-right font-mono font-semibold">{fmt(it.total)}</td>
              </tr>
            ))}
          </tbody>
          <tfoot>
            <tr><td colspan="3" class="py-2 text-right text-neutral-500">Subtotal</td><td class="py-2 text-right font-mono">{fmt(sale.subtotal)}</td></tr>
            <tr><td colspan="3" class="py-2 text-right text-neutral-500">IVA</td><td class="py-2 text-right font-mono">{fmt(sale.ivaTotal)}</td></tr>
            <tr><td colspan="3" class="py-2 text-right font-heading font-bold text-neutral-900">Total</td><td class="py-2 text-right font-mono text-xl font-bold text-brand-blue">{fmt(sale.total)}</td></tr>
          </tfoot>
        </table>

        <div class="mt-6 border-t border-neutral-100 pt-4 text-center">
          <button onclick="window.print()" class="rounded-lg bg-brand-blue px-5 py-2.5 text-sm font-semibold text-white">Imprimir o guardar PDF</button>
        </div>
      </section>
    </main>
  </body>
</html>
